#!/bin/bash
# Wrapper around the slm CLI that always scopes to the project-local
# memory database at ./.slm/. The opencode.jsonc config only affects
# the MCP server process; the CLI talks to a long-running daemon that
# captured its SL_MEMORY_PATH at startup. This wrapper makes the CLI
# safe by setting the env var explicitly, regardless of how the
# daemon was started.
#
# Usage:
#   ./bin/slm-local status
#   ./bin/slm-local remember "..." --tags "..."
#   ./bin/slm-local recall "..."
#
# See AGENTS.md "the daemon gotcha" for the full story.

set -euo pipefail

# Resolve the project root: this script lives at <root>/bin/slm-local,
# so the project root is the parent of the script's directory.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Force project-local scope
export SL_MEMORY_PATH="$PROJECT_ROOT/.slm"

exec slm "$@"
